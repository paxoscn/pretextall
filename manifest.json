{
  "manifest_version": 3,
  "name": "PreTextAll",
  "version": "1.0.0",
  "description": "让自定义动画跟随鼠标与网页文字产生互动效果",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pretext-loader.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "pretext-lib/*", "dog.gif"],
      "matches": ["<all_urls>"]
    }
  ]
}
